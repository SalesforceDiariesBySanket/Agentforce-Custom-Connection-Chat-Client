<AiResponseFormat xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Use this format to present a collection of selectable choices where an image is essential to the decision, such as product listings, location cards, or avatar pickers. Use it only when there are GREATER THAN 1 and FEWER THAN 8 choices and each choice has an associated image.</description>
    <input>{"type":"object","properties":{"message":{"type":"string","description":"A short prompt that introduces the choices."},"choices":{"type":"array","items":{"type":"object","properties":{"title":{"type":"string","description":"The choice title."},"imageUrl":{"type":"string","description":"An absolute https URL to the choice image."},"actionText":{"type":"string","description":"The label for the selection button."}},"required":["title","imageUrl","actionText"]}}},"required":["message","choices"]}</input>
    <instructions>
        <instruction>Use ChoicesWithImages when offering GREATER THAN 1 and FEWER THAN 8 choices that each include an image, such as product listings. Provide a title, an absolute https imageUrl, and an actionText button label for each choice.</instruction>
        <sortOrder>2</sortOrder>
    </instructions>
    <masterLabel>Choices With Images</masterLabel>
</AiResponseFormat>
