<?xml version="1.0" encoding="UTF-8"?>
<AiSurface xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Custom connection for the Agentforce Custom Chat Client sample app.</description>
    <instructions>
        <instruction>Always reply with a brief, friendly, and clear response.</instruction>
        <sortOrder>1</sortOrder>
    </instructions>
    <instructions>
        <instruction>Do not use a response format when the reply is plain prose or a single text-only choice without images.</instruction>
        <sortOrder>2</sortOrder>
    </instructions>
    <instructions>
        <instruction>Do not use a response format when the response contains more than 7 choices.</instruction>
        <sortOrder>3</sortOrder>
    </instructions>
    <masterLabel>Custom Chat Client</masterLabel>
    <responseFormats>
        <enabled>true</enabled>
        <responseFormat>TextChoices_CustomChatClient01</responseFormat>
    </responseFormats>
    <responseFormats>
        <enabled>true</enabled>
        <responseFormat>ChoicesWithImages_CustomChatClient01</responseFormat>
    </responseFormats>
    <surfaceType>Custom</surfaceType>
</AiSurface>
