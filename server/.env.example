# --- Agent API connection (required) ---
# My Domain URL (Setup > My Domain > Current My Domain URL), include https://
SF_MY_DOMAIN_URL=https://your-domain.my.salesforce.com
# External Client App consumer key & secret (client credentials flow)
SF_CLIENT_ID=
SF_CLIENT_SECRET=
# Agent ID (0Xx...) of the agent to converse with
SF_AGENT_ID=

# --- Optional ---
# Agent API host. Default: https://api.salesforce.com
# Government Cloud: https://api.gov.salesforce.com
SF_API_HOST=https://api.salesforce.com
# Session surface type. "Custom" enables custom-connection response formats.
SF_SURFACE_TYPE=Custom
# bypassUser control: "true" (default, per docs for client credentials),
# "false", or "omit" (leave the field out). If you hit
# "Invalid user ID provided on start session", try "omit".
SF_BYPASS_USER=true
# CORS origin allowed for the browser client (default http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173
# Server port (default 8080)
PORT=8080
